# ═══════════════════════════════════════════════════════════════
# NeuralMigrate — Option A Setup (No Docker, No Ollama)
# All free cloud services. Copy to .env and fill in your keys.
# ═══════════════════════════════════════════════════════════════

# ── LLM: Groq (free) ─────────────────────────────────────────
# Sign up free at https://groq.com — no credit card needed
# Get your key at https://console.groq.com/keys
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_paste_your_key_here
GROQ_MODEL=llama3-8b-8192

# ── Embeddings: HuggingFace sentence-transformers (free) ──────
# Downloads ~90MB model on first run, cached locally after that
# No sign-up, no API key, runs on CPU
EMBEDDING_PROVIDER=huggingface
HF_EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Neo4j: Aura Free (cloud graph database) ───────────────────
# Sign up free at https://neo4j.com/cloud/aura/
# Create an AuraDB Free instance, copy the connection details
NEO4J_URI=neo4j+s://PASTE_YOUR_AURA_URI_HERE.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=paste_your_aura_password_here

# ── PostgreSQL: Neon Free (cloud, pgvector supported) ─────────
# Sign up free at https://neon.tech — no credit card
# Create a project, copy the connection string from dashboard
PG_DSN=postgresql://user:password@ep-your-endpoint.neon.tech/neondb?sslmode=require

# ── Pipeline ──────────────────────────────────────────────────
MAX_ITERATIONS=3

# ── API server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# CORS: add your Vercel URL when deployed
# e.g. https://neuralmigrate-xyz.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# ── API key protection (optional) ────────────────────────────
# Leave blank for local dev. Set a random string in production.
API_KEY=

# ── SQLite history ────────────────────────────────────────────
HISTORY_DB=migration_history.db

# ─────────────────────────────────────────────────────────────
# NOT NEEDED for Option A:
# OPENAI_API_KEY=      (only if switching to OpenAI)
# OLLAMA_BASE_URL=     (only if using local Ollama)
# DEEPSEEK_API_KEY=    (only if using DeepSeek)
# ─────────────────────────────────────────────────────────────
